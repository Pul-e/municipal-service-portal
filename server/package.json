{
  "name": "municipal-service-backend",
  "version": "1.0.0",
  "description": "Backend API for Municipal Service Delivery Reporting Portal",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
  "setupFiles": [
    "<rootDir>/tests/setupEnv.js"
  ],
  "collectCoverageFrom": [
    "index.js",
    "routes/**/*.js",
    "middleware/**/*.js"
  ]
},
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  }
}
